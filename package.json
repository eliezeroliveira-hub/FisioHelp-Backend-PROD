{
  "name": "mvp-backend",
  "version": "1.0.0",
  "description": "API backend do MVP FisioApp",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "npx eslint .",
    "check:env": "node -e \"require('dotenv').config(); console.log(process.env);\"",
    "uploads:blob:dry-run": "node scripts/migrarUploadsParaBlob.js --dry-run",
    "uploads:blob:migrate": "node scripts/migrarUploadsParaBlob.js",
    "test": "echo \"No tests configured yet.\" && exit 0"
  },
  "keywords": [
    "express",
    "mssql",
    "api",
    "backend",
    "fisioapp"
  ],
  "author": "Eliezer Oliveira",
  "license": "ISC",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1068.0",
    "@azure/communication-email": "^1.1.0",
    "@azure/storage-blob": "^12.32.0",
    "apple-signin-auth": "^2.0.0",
    "axios": "^1.7.3",
    "bcrypt": "^6.0.0",
    "chalk": "^5.3.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "file-type": "^22.0.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "mssql": "^12.0.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.17.2",
    "redis": "^4.7.0",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^6.0.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "nodemon": "^3.1.10"
  }
}
